{
  "name": "hara-zalous",
  "version": "0.3.0",
  "description": "Spicetify-like patch CLI for Zalo Desktop",
  "main": "tools/zalous-cli.js",
  "bin": {
    "zalous": "tools/zalous-cli.js"
  },
  "scripts": {
    "zalous": "node tools/zalous-cli.js",
    "build:email-prototype": "node tools/build-email-prototype.js",
    "build:exe": "pkg . --targets node18-win-x64 --output dist/zalous.exe"
  },
  "pkg": {
    "assets": [
      "zalous/runtime/**/*.js",
      "zalous/market/**/*.json",
      "zalous/market/packs/**/*"
    ]
  },
  "dependencies": {
    "@electron/asar": "^3.2.8"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
